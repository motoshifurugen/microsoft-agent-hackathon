# syntax=docker/dockerfile:1.7

# Stage 1: Vite build (Node 20)
FROM node:20-slim AS frontend
WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm ci --no-audit --no-fund
COPY frontend ./
RUN npm run build


# Stage 2: Python deps (uv)
FROM python:3.12-slim AS builder

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:0.5.4 /uv /usr/local/bin/uv

COPY pyproject.toml uv.lock* ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

COPY src/ ./src/
COPY README.md ./
COPY docs/sample_data ./docs/sample_data
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev


# Stage 3: Runtime
FROM python:3.12-slim

WORKDIR /app

COPY --from=builder /app /app
# Vite ビルド成果物を /app/frontend_dist に配置。src/api/main.py の StaticFiles が拾う。
COPY --from=frontend /app/frontend/dist /app/frontend_dist

ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PORT=8000

EXPOSE 8000

# FastAPI が API (/api/*) と 静的フロント (/*) を 1 ポートで配信
CMD ["uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "8000"]

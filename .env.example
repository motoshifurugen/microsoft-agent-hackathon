# Azure AI Foundry プロジェクトのエンドポイント
# 例: https://<your-foundry-resource>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=

# モデルデプロイ名 (省略時 gpt-4o)
MODEL_DEPLOYMENT=gpt-4o

# 埋め込みモデルデプロイ名 (semantic_search で使用)
# Foundry に text-embedding-3-small をデプロイ済み
EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Orchestrator Agent の ID (scripts/create_agents.py の出力)
# 後方互換のため変数名は AGENT_ID を維持しており、値は Orchestrator を指す
AGENT_ID=

# 子 Agent の ID (scripts/create_agents.py の出力)
# Orchestrator が ConnectedAgentTool で呼び分けるため、src/app.py からは直接参照しない
AGENT_ID_OBSERVER=
AGENT_ID_COLLECTOR=
AGENT_ID_MATCHER=
AGENT_ID_PROPOSER=

# (任意) ローカルで Service Principal 認証を使う場合
# 通常は `az login` で DefaultAzureCredential が解決するため不要
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- Slack「はてなボックス」連携 (任意。3 つ揃うと起動時に Socket Mode Bot を起動) ---
# Bot User OAuth Token。必要 Scope: channels:history, chat:write
SLACK_BOT_TOKEN=
# App-Level Token (Socket Mode を有効化すると発行される xapp- トークン)
SLACK_APP_TOKEN=
# 対象チャネル「#はてなボックス」のチャネル ID (例: C0123456789)
SLACK_HATENA_CHANNEL_ID=
# (任意) チャネル表示名。省略時は「はてなボックス」
# SLACK_HATENA_CHANNEL_NAME=はてなボックス
# Kodama のベース URL。Slack 返信に含めるカテゴリ画面 URL の生成に使う
KODAMA_BASE_URL=http://localhost:8000

# Azure AI Foundry プロジェクトのエンドポイント
# 例: https://<your-foundry-resource>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=

# モデルデプロイ名 (省略時 gpt-4o)
MODEL_DEPLOYMENT=gpt-4o

# 埋め込みモデルデプロイ名 (semantic_search で使用)
# Foundry に text-embedding-3-small をデプロイ済み
EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Orchestrator Agent の ID (scripts/create_agents.py の出力)
# 後方互換のため変数名は AGENT_ID を維持しており、値は Orchestrator を指す
AGENT_ID=

# 子 Agent の ID (scripts/create_agents.py の出力)
# Orchestrator が ConnectedAgentTool で呼び分けるため、src/app.py からは直接参照しない
AGENT_ID_OBSERVER=
AGENT_ID_COLLECTOR=
AGENT_ID_MATCHER=
AGENT_ID_PROPOSER=

# (任意) ローカルで Service Principal 認証を使う場合
# 通常は `az login` で DefaultAzureCredential が解決するため不要
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
